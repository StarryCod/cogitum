#!/usr/bin/env node
const { spawnSync } = require('child_process');
const path = require('path');
const os = require('os');
const fs = require('fs');

const INSTALL_DIR = path.join(os.homedir(), '.local', 'share', 'cogitum');
const VENV_DIR = path.join(INSTALL_DIR, '.venv');
const COG = path.join(VENV_DIR, 'bin', 'cog');
const REPO = 'https://github.com/StarryCod/cogitum.git';

const G = '\x1b[32m';
const R = '\x1b[31m';
const Y = '\x1b[33m';
const N = '\x1b[0m';

function log(msg)  { console.log(`${G}⚔${N} ${msg}`); }
function warn(msg) { console.log(`${Y}⚠${N} ${msg}`); }
function err(msg)  { console.error(`${R}✗${N} ${msg}`); }

function run(cmd, args, silent = false) {
  return spawnSync(cmd, args, {
    stdio: silent ? ['pipe', 'pipe', 'pipe'] : 'inherit',
    encoding: 'utf-8',
  });
}

function findPython() {
  for (const py of ['python3.11', 'python3.12', 'python3.13', 'python3']) {
    const r = run(py, ['--version'], true);
    if (r.status === 0) {
      const m = (r.stdout || r.stderr || '').match(/(\d+)\.(\d+)/);
      if (m) {
        const major = parseInt(m[1], 10);
        const minor = parseInt(m[2], 10);
        if (major > 3 || (major === 3 && minor >= 11)) return py;
      }
    }
  }
  return null;
}

function checkDep(name) {
  const r = run(path.join(VENV_DIR, 'bin', 'python'), ['-c', `import ${name}`], true);
  return r.status === 0;
}

function getLocalCommit() {
  const r = run('git', ['-C', INSTALL_DIR, 'rev-parse', 'HEAD'], true);
  return r.status === 0 ? r.stdout.trim() : '';
}

function getRemoteCommit() {
  const r = run('git', ['-C', INSTALL_DIR, 'ls-remote', '--heads', 'origin', 'master'], true);
  if (r.status !== 0) return '';
  const parts = r.stdout.trim().split(/\s+/);
  return parts[0] || '';
}

function install(force = false) {
  const python = findPython();
  if (!python) {
    err('Python 3.11+ is required but not found.');
    err('Install it first: sudo apt install python3.11 python3.11-venv');
    process.exit(1);
  }

  if (!fs.existsSync(INSTALL_DIR)) {
    log('First run — cloning Cogitum ...');
    const r = run('git', ['clone', '--depth', '1', REPO, INSTALL_DIR]);
    if (r.status !== 0) {
      err('git clone failed. Is git installed?');
      process.exit(1);
    }
  }

  if (!fs.existsSync(VENV_DIR)) {
    log('Creating virtual environment ...');
    const r = run(python, ['-m', 'venv', VENV_DIR]);
    if (r.status !== 0) {
      err('Failed to create venv');
      process.exit(1);
    }
  }

  const venvPy = path.join(VENV_DIR, 'bin', 'python');

  if (!force) {
    log('Checking for updates ...');
    run('git', ['-C', INSTALL_DIR, 'fetch', '--depth', '1', 'origin', 'master']);
    const local = getLocalCommit();
    const remote = getRemoteCommit();
    if (local && remote && local === remote) {
      log('Already up to date.');
      return true;
    }
  }

  log('Updating Cogitum ...');
  run('git', ['-C', INSTALL_DIR, 'reset', '--hard', 'origin/master']);

  log('Installing Python dependencies ...');
  run(venvPy, ['-m', 'pip', 'install', '--upgrade', 'pip']);
  const r = run(venvPy, ['-m', 'pip', 'install', '-e', `${INSTALL_DIR}[all]`]);
  if (r.status !== 0) {
    err('pip install failed.');
    process.exit(1);
  }

  if (!checkDep('tomlkit')) {
    err('Installation verification failed — tomlkit missing.');
    process.exit(1);
  }

  log('Ready!');
  return true;
}

// First install if missing
if (!fs.existsSync(COG)) {
  install(true);
} else {
  // Check for updates every run
  install(false);
}

const result = spawnSync(COG, process.argv.slice(2), { stdio: 'inherit', env: process.env });
process.exit(result.status ?? 0);
